{
    "name": "kodbee/paydiver-php",
    "description": "Official PHP client for the Paydiver payment API by Kodbee — create payments, verify transactions, check status/balance and validate webhooks.",
    "type": "library",
    "keywords": ["paydiver", "kodbee", "payment", "bangladesh", "bkash", "nagad", "rocket", "upay", "sdk"],
    "homepage": "https://kodbee.com",
    "license": "MIT",
    "authors": [
        {
            "name": "Kodbee",
            "email": "info@kodbee.com",
            "homepage": "https://kodbee.com"
        }
    ],
    "support": {
        "issues": "https://github.com/kodbeedev/paydiver-php/issues",
        "source": "https://github.com/kodbeedev/paydiver-php"
    },
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Kodbee\\Paydiver\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kodbee\\Paydiver\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
